DATABASE_URL=postgresql://postgres:password@localhost:5433/chumzy_rawfoods
PORT=8080
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
# Initial admin credentials — used by `npm run db:seed` to create the first
# admin_users row (password is bcrypt-hashed). Login verifies against the
# database, not these vars directly.
ADMIN_EMAIL=admin@chumzy.com
ADMIN_PASSWORD=change-me
JWT_SECRET=change-this-to-a-long-random-string
